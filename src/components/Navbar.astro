---

---

<div
    class="hidden md:block bg-brand-primary text-white text-[11px] py-1 border-b border-white/10 relative z-50 w-full transition-all"
>
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
        <!-- Info Izquierda -->
        <div class="flex items-center gap-4">
            <a
                href="mailto:info@exportadoranorandino.com"
                class="flex items-center gap-1.5 hover:text-brand-tertiary transition-colors"
                title="Enviar correo a info@exportadoranorandino.com"
            >
                <span class="material-symbols-rounded text-[14px]">mail</span>
                info@exportadoranorandino.com
            </a>
            <div class="flex items-center gap-1.5">
                <span class="material-symbols-rounded text-[14px]"
                    >location_on</span
                >
                Av. Despensa N° 1550, J.L. Ortiz, Lambayeque – Perú
            </div>
        </div>

        <!-- Info Derecha -->
        <div class="flex items-center gap-4">
            <div class="flex items-center gap-1.5 font-medium">
                <span class="material-symbols-rounded text-[14px]">call</span>
                <div class="flex items-center gap-3">
                    <a
                        href="tel:+51921113910"
                        class="hover:text-brand-tertiary transition-colors"
                        >+51 921 113 910</a
                    >
                    <span class="text-white/40 text-[10px]">|</span>
                    <a
                        href="tel:+51922398538"
                        class="hover:text-brand-tertiary transition-colors"
                        >+51 922 398 538</a
                    >
                </div>
            </div>
            <div class="w-px h-3 bg-white/30 hidden lg:block"></div>
            <!-- Redes Sociales -->
            <div class="flex items-center gap-2.5">
                <a
                    href="https://web.facebook.com/profile.php?id=61578668040989"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-brand-tertiary transition-colors"
                    aria-label="Facebook"
                >
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                            clip-rule="evenodd"></path></svg
                    >
                </a>
                <a
                    href="https://www.linkedin.com/in/moises-altamirano-agroexport"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-brand-tertiary transition-colors"
                    aria-label="LinkedIn"
                >
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                            clip-rule="evenodd"></path></svg
                    >
                </a>
            </div>
        </div>
    </div>
</div>

<nav
    id="main-nav"
    class="nav-glass w-full border-b border-transparent transition-all duration-300 sticky top-0 z-50"
>
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <!-- Logo (Left) -->
        <a href="/#" class="flex items-center group w-[200px]">
            <img
                src="/logo.png"
                alt="Logo Exportadora Norandino"
                class="h-18 md:h-18 w-auto object-contain transition-transform group-hover:scale-105"
            />
        </a>

        <!-- Desktop Nav (Center) -->
        <div
            class="hidden md:flex justify-center flex-1 items-center gap-8 text-sm font-semibold text-gray-700 whitespace-nowrap"
        >
            <a
                href="/"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Inicio</a
            >
            <a
                href="/#nosotros"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Nosotros</a
            >
            <a
                href="/#productos"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Productos</a
            >
            <a
                href="/#calidad"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Calidad</a
            >
            <a
                href="/#exportaciones"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Exportaciones</a
            >
        </div>

        <!-- Desktop CTA (Right) -->
        <div class="hidden md:flex justify-end w-[200px]">
            <a
                href="/contacto"
                class="bg-brand-secondary hover:bg-[#2eaa40] text-white px-5 py-2.5 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-brand-secondary/25"
                >Contáctanos</a
            >
        </div>

        <!-- Mobile Hamburger -->
        <button
            id="mobile-toggle"
            class="md:hidden flex flex-col gap-1.5 p-2"
            aria-label="Menú"
        >
            <span class="w-6 h-0.5 bg-gray-700 rounded transition-all"></span>
            <span class="w-6 h-0.5 bg-gray-700 rounded transition-all"></span>
            <span class="w-4 h-0.5 bg-gray-700 rounded transition-all"></span>
        </button>
    </div>
</nav>

<!-- Mobile Menu Backdrop (outside nav to avoid z-index clipping) -->
<div
    id="mobile-menu-backdrop"
    class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[9000] hidden opacity-0 transition-opacity duration-300 md:hidden"
>
</div>

<!-- Mobile Menu Drawer (outside nav, slides from right) -->
<div
    id="mobile-menu"
    class="fixed top-0 right-0 h-full w-[85%] max-w-sm bg-white shadow-2xl z-[9001] transform translate-x-full transition-transform duration-300 ease-out flex flex-col md:hidden"
>
    <!-- Header (Logo Central + Cerrar) -->
    <div
        class="flex items-center justify-between px-5 py-6 border-b border-gray-100 relative"
    >
        <div class="flex-1 flex justify-center">
            <img
                src="/logo.png"
                alt="Logo Exportadora Norandino"
                class="h-20 w-auto object-contain"
            />
        </div>
        <button
            id="mobile-close"
            class="absolute right-4 top-4 text-gray-400 hover:text-brand-secondary transition-colors p-1 flex items-center justify-center"
            aria-label="Cerrar menú"
        >
            <span class="material-symbols-rounded text-2xl">close</span>
        </button>
    </div>

    <!-- Scrollable interior -->
    <div class="flex flex-col flex-1 overflow-y-auto">
        <!-- Links Principales -->
        <div class="flex flex-col px-6 pt-6 pb-2 gap-1">
            <a
                href="/"
                class="block py-3 text-gray-700 hover:text-brand-secondary font-medium text-lg border-b border-gray-100"
                >Inicio</a
            >
            <a
                href="/#nosotros"
                class="block py-3 text-gray-700 hover:text-brand-secondary font-medium text-lg border-b border-gray-100"
                >Nosotros</a
            >
            <a
                href="/#productos"
                class="block py-3 text-gray-700 hover:text-brand-secondary font-medium text-lg border-b border-gray-100"
                >Productos</a
            >
            <a
                href="/#calidad"
                class="block py-3 text-gray-700 hover:text-brand-secondary font-medium text-lg border-b border-gray-100"
                >Calidad</a
            >
            <a
                href="/#exportaciones"
                class="block py-3 text-gray-700 hover:text-brand-secondary font-medium text-lg border-b border-gray-100"
                >Exportaciones</a
            >
            <a
                href="/contacto"
                class="block py-3 text-brand-secondary font-bold text-lg"
                >Contáctanos</a
            >
        </div>

        <!-- Síguenos (Redes sociales) -->
        <div class="px-6 py-4 border-t border-gray-100">
            <p
                class="text-xs text-gray-400 font-semibold tracking-widest uppercase mb-3 text-center"
            >
                Síguenos
            </p>
            <div class="flex gap-3 justify-center">
                <a
                    href="https://web.facebook.com/profile.php?id=61578668040989"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-gray-50 border border-gray-200 flex items-center justify-center text-gray-500 hover:text-blue-600 hover:border-blue-600 transition-all"
                    aria-label="Facebook"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                            clip-rule="evenodd"></path></svg
                    >
                </a>
                <a
                    href="https://www.linkedin.com/in/moises-altamirano-agroexport"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-gray-50 border border-gray-200 flex items-center justify-center text-gray-500 hover:text-blue-700 hover:border-blue-700 transition-all"
                    aria-label="LinkedIn"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                            clip-rule="evenodd"></path></svg
                    >
                </a>
            </div>
        </div>

        <!-- Contacto -->
        <div
            class="mx-6 mb-6 rounded-2xl bg-gray-50 border border-gray-100 p-4 flex flex-col gap-3"
        >
            <p
                class="text-xs text-gray-400 font-semibold tracking-widest uppercase"
            >
                Contacto
            </p>
            <!-- Teléfonos -->
            <a
                href="tel:+51921113910"
                class="flex items-center gap-3 text-gray-700 hover:text-brand-secondary transition-colors"
            >
                <div
                    class="w-8 h-8 rounded-full bg-brand-secondary/10 flex items-center justify-center shrink-0"
                >
                    <span
                        class="material-symbols-rounded text-brand-secondary text-base"
                        >call</span
                    >
                </div>
                <div>
                    <p class="text-sm font-semibold leading-tight">
                        +51 921 113 910
                    </p>
                    <p class="text-xs text-gray-400">+51 922 398 538</p>
                </div>
            </a>
            <!-- Email -->
            <a
                href="mailto:info.exponorandino@gmail.com"
                class="flex items-center gap-3 text-gray-700 hover:text-brand-secondary transition-colors"
            >
                <div
                    class="w-8 h-8 rounded-full bg-brand-primary/10 flex items-center justify-center shrink-0"
                >
                    <span
                        class="material-symbols-rounded text-brand-primary text-base"
                        >mail</span
                    >
                </div>
                <p class="text-sm font-semibold leading-tight">
                    info.exponorandino@gmail.com
                </p>
            </a>
        </div>
    </div>
</div>

<script>
    // Mobile menu toggle
    const toggle = document.getElementById("mobile-toggle");
    const menu = document.getElementById("mobile-menu");
    const backdrop = document.getElementById("mobile-menu-backdrop");
    const closeBtn = document.getElementById("mobile-close");

    function openMenu() {
        backdrop?.classList.remove("hidden");
        // trigger reflow for transition
        if (backdrop) void backdrop.offsetWidth;
        backdrop?.classList.remove("opacity-0");
        menu?.classList.remove("translate-x-full");
        document.body.style.overflow = "hidden";
    }

    function closeMenu() {
        backdrop?.classList.add("opacity-0");
        menu?.classList.add("translate-x-full");
        setTimeout(() => {
            backdrop?.classList.add("hidden");
            document.body.style.overflow = "";
        }, 300);
    }

    toggle?.addEventListener("click", openMenu);
    closeBtn?.addEventListener("click", closeMenu);
    backdrop?.addEventListener("click", closeMenu);

    // Close mobile menu on link click
    menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMenu);
    });
</script>
