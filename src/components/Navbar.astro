---

<div
    class="hidden md:block bg-brand-primary text-white text-[11px] py-1 border-b border-white/10 relative z-50 w-full transition-all"
>
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
        <!-- Info Izquierda -->
        <div class="flex items-center gap-4">
            <a
                href="mailto:info@exportadoranorandino.com"
                class="flex items-center gap-1.5 hover:text-brand-tertiary transition-colors"
                title="Enviar correo a info@exportadoranorandino.com"
            >
                <span class="material-symbols-rounded text-[14px]">mail</span>
                info@exportadoranorandino.com
            </a>
            <div class="flex items-center gap-1.5">
                <span class="material-symbols-rounded text-[14px]"
                    >location_on</span
                >
                Av. Despensa N° 1550, J.L. Ortiz, Lambayeque – Perú
            </div>
        </div>

        <!-- Info Derecha -->
        <div class="flex items-center gap-4">
            <div class="flex items-center gap-1.5 font-medium">
                <span class="material-symbols-rounded text-[14px]">call</span>
                <a
                    href="tel:+51922398538"
                    class="hover:text-brand-tertiary transition-colors"
                    >+51 922 398 538</a
                >
                <span class="text-white/40">|</span>
                <a
                    href="tel:+51973845374"
                    class="hover:text-brand-tertiary transition-colors"
                    >+51 973 845 374</a
                >
            </div>
            <div class="w-px h-3 bg-white/30 hidden lg:block"></div>
            <!-- Redes Sociales -->
            <div class="flex items-center gap-2.5">
                <a
                    href="#"
                    class="hover:text-brand-tertiary transition-colors"
                    aria-label="Facebook"
                >
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                            clip-rule="evenodd"></path></svg
                    >
                </a>
                <a
                    href="#"
                    class="hover:text-brand-tertiary transition-colors"
                    aria-label="Instagram"
                >
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
                            clip-rule="evenodd"></path></svg
                    >
                </a>
                <a
                    href="#"
                    class="hover:text-brand-tertiary transition-colors"
                    aria-label="LinkedIn"
                >
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                            clip-rule="evenodd"></path></svg
                    >
                </a>
            </div>
        </div>
    </div>
</div>

<nav
    id="main-nav"
    class="nav-glass w-full border-b border-transparent transition-all duration-300"
>
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <!-- Logo (Left) -->
        <a href="/#" class="flex items-center group w-[200px]">
            <img
                src="/logo.png"
                alt="Logo Exportadora Norandino"
                class="h-14 md:h-16 w-auto object-contain transition-transform group-hover:scale-105"
            />
        </a>

        <!-- Desktop Nav (Center) -->
        <div
            class="hidden md:flex justify-center flex-1 items-center gap-8 text-sm font-semibold text-gray-700 whitespace-nowrap"
        >
            <a
                href="/"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Inicio</a
            >
            <a
                href="/#nosotros"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Nosotros</a
            >
            <a
                href="/#productos"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Productos</a
            >
            <a
                href="/#calidad"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Calidad</a
            >
        </div>

        <!-- Desktop CTA (Right) -->
        <div class="hidden md:flex justify-end w-[200px]">
            <a
                href="/contacto"
                class="bg-brand-secondary hover:bg-[#2eaa40] text-white px-5 py-2.5 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-brand-secondary/25"
                >Contáctanos</a
            >
        </div>

        <!-- Mobile Hamburger -->
        <button
            id="mobile-toggle"
            class="md:hidden flex flex-col gap-1.5 p-2"
            aria-label="Menú"
        >
            <span class="w-6 h-0.5 bg-gray-700 rounded transition-all"></span>
            <span class="w-6 h-0.5 bg-gray-700 rounded transition-all"></span>
            <span class="w-4 h-0.5 bg-gray-700 rounded transition-all"></span>
        </button>
    </div>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="hidden md:hidden bg-white/95 backdrop-blur-md px-6 pb-4 border-t border-gray-100"
    >
        <a
            href="/"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Inicio</a
        >
        <a
            href="/#nosotros"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Nosotros</a
        >
        <a
            href="/#productos"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Productos</a
        >
        <a
            href="/#calidad"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Calidad</a
        >
        <a href="/contacto" class="block py-3 text-brand-secondary font-bold"
            >Contáctanos</a
        >
    </div>
</nav>

<script>
    // Mobile menu toggle
    const toggle = document.getElementById("mobile-toggle");
    const menu = document.getElementById("mobile-menu");

    toggle?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
    });

    // Close mobile menu on link click
    menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => menu?.classList.add("hidden"));
    });
</script>
