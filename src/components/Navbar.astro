---

---

<nav
    id="main-nav"
    class="nav-glass w-full border-b border-transparent transition-all duration-300"
>
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <!-- Logo (Left) -->
        <a href="/#" class="flex items-center group w-[200px]">
            <img
                src="/logo.png"
                alt="Logo Exportadora Norandino"
                class="h-14 md:h-16 w-auto object-contain transition-transform group-hover:scale-105"
            />
        </a>

        <!-- Desktop Nav (Center) -->
        <div
            class="hidden md:flex justify-center flex-1 items-center gap-8 text-sm font-semibold text-gray-700 whitespace-nowrap"
        >
            <a
                href="/"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Inicio</a
            >
            <a
                href="/#nosotros"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Nosotros</a
            >
            <a
                href="/#productos"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Productos</a
            >
            <a
                href="/#calidad"
                class="hover:text-brand-secondary transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 hover:after:w-full after:h-0.5 after:bg-brand-secondary after:transition-all"
                >Calidad</a
            >
        </div>

        <!-- Desktop CTA (Right) -->
        <div class="hidden md:flex justify-end w-[200px]">
            <a
                href="/contacto"
                class="bg-brand-secondary hover:bg-[#2eaa40] text-white px-5 py-2.5 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-brand-secondary/25"
                >Contáctanos</a
            >
        </div>

        <!-- Mobile Hamburger -->
        <button
            id="mobile-toggle"
            class="md:hidden flex flex-col gap-1.5 p-2"
            aria-label="Menú"
        >
            <span class="w-6 h-0.5 bg-gray-700 rounded transition-all"></span>
            <span class="w-6 h-0.5 bg-gray-700 rounded transition-all"></span>
            <span class="w-4 h-0.5 bg-gray-700 rounded transition-all"></span>
        </button>
    </div>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="hidden md:hidden bg-white/95 backdrop-blur-md px-6 pb-4 border-t border-gray-100"
    >
        <a
            href="/"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Inicio</a
        >
        <a
            href="/#nosotros"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Nosotros</a
        >
        <a
            href="/#productos"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Productos</a
        >
        <a
            href="/#calidad"
            class="block py-3 text-gray-700 hover:text-brand-secondary font-medium border-b border-gray-100"
            >Calidad</a
        >
        <a href="/contacto" class="block py-3 text-brand-secondary font-bold"
            >Contáctanos</a
        >
    </div>
</nav>

<script>
    // Mobile menu toggle
    const toggle = document.getElementById("mobile-toggle");
    const menu = document.getElementById("mobile-menu");

    toggle?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
    });

    // Close mobile menu on link click
    menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => menu?.classList.add("hidden"));
    });

    /* Navbar shrink on scroll - Disabled while Navbar is not fixed
    window.addEventListener("scroll", () => {
        const nav = document.getElementById("main-nav");
        if (window.scrollY > 50) {
            nav?.classList.add("bg-white/95", "backdrop-blur-md", "shadow-sm");
            nav?.classList.remove("bg-transparent");
        } else {
            nav?.classList.remove(
                "bg-white/95",
                "backdrop-blur-md",
                "shadow-sm",
            );
            nav?.classList.add("bg-transparent");
        }
    });
    */
</script>
