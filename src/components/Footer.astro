---
// src/components/Footer.astro
---

<footer
    id="contacto"
    class="relative overflow-hidden bg-gradient-to-b from-white to-gray-100 pt-16 pb-8"
>
    <!-- Barra superior de acento con degradado -->
    <div
        class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-brand-primary via-brand-secondary to-brand-tertiary"
    >
    </div>

    <!-- Decoración de fondo sutil -->
    <div
        class="absolute bottom-0 right-0 w-1/2 h-full bg-gradient-to-tl from-brand-secondary/5 to-transparent pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
            <!-- Columna 1: Branding -->
            <div class="space-y-6">
                <!-- Logo integrado naturalmente sin contenedor blanco -->
                <a href="/#" class="inline-block group">
                    <img
                        src="/logo.png"
                        alt="Logo Norandino"
                        class="h-14 md:h-16 w-auto object-contain transition-transform duration-500 group-hover:scale-105"
                    />
                </a>
                <p class="text-gray-600 text-sm leading-relaxed max-w-xs">
                    Exportadora Norandino S.A.C. — Calidad agrícola peruana para
                    el mundo. Especialistas en el procesamiento y exportación de
                    productos frescos.
                </p>
                <!-- Redes Sociales -->
                <div class="flex items-center gap-4">
                    <a
                        href="#"
                        class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-gray-400 hover:bg-brand-secondary hover:text-white transition-all duration-300 shadow-sm border border-gray-100 hover:border-brand-secondary hover:-translate-y-1"
                        aria-label="Facebook"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="#"
                        class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-gray-400 hover:bg-brand-secondary hover:text-white transition-all duration-300 shadow-sm border border-gray-100 hover:border-brand-secondary hover:-translate-y-1"
                        aria-label="Instagram"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            ><rect
                                x="2"
                                y="2"
                                width="20"
                                height="20"
                                rx="5"
                                ry="5"></rect><path
                                d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="#"
                        class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-gray-400 hover:bg-brand-secondary hover:text-white transition-all duration-300 shadow-sm border border-gray-100 hover:border-brand-secondary hover:-translate-y-1"
                        aria-label="LinkedIn"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"
                            ></path><circle cx="4" cy="4" r="2"></circle></svg
                        >
                    </a>
                </div>
            </div>

            <!-- Columna 2: Navegación -->
            <div>
                <h3
                    class="text-brand-primary font-bold text-lg mb-6 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 bg-brand-secondary rounded-full"
                    ></span> Enlaces Rápidos
                </h3>
                <ul class="space-y-4">
                    <li>
                        <a
                            href="/"
                            class="text-gray-600 hover:text-brand-secondary transition-colors text-sm flex items-center gap-2 group"
                            ><span
                                class="material-symbols-rounded text-[14px] opacity-0 -ml-4 group-hover:opacity-100 group-hover:ml-0 transition-all text-brand-secondary"
                                >chevron_right</span
                            > Inicio</a>
                    </li>
                    <li>
                        <a
                            href="/#nosotros"
                            class="text-gray-600 hover:text-brand-secondary transition-colors text-sm flex items-center gap-2 group"
                            ><span
                                class="material-symbols-rounded text-[14px] opacity-0 -ml-4 group-hover:opacity-100 group-hover:ml-0 transition-all text-brand-secondary"
                                >chevron_right</span
                            > Nosotros</a>
                    </li>
                    <li>
                        <a
                            href="/#productos"
                            class="text-gray-600 hover:text-brand-secondary transition-colors text-sm flex items-center gap-2 group"
                            ><span
                                class="material-symbols-rounded text-[14px] opacity-0 -ml-4 group-hover:opacity-100 group-hover:ml-0 transition-all text-brand-secondary"
                                >chevron_right</span
                            > Productos</a>
                    </li>
                    <li>
                        <a
                            href="/#calidad"
                            class="text-gray-600 hover:text-brand-secondary transition-colors text-sm flex items-center gap-2 group"
                            ><span
                                class="material-symbols-rounded text-[14px] opacity-0 -ml-4 group-hover:opacity-100 group-hover:ml-0 transition-all text-brand-secondary"
                                >chevron_right</span
                            > Calidad</a>
                    </li>
                    <li>
                        <a
                            href="/contacto"
                            class="text-brand-primary font-medium hover:text-brand-secondary transition-colors text-sm flex items-center gap-2 group"
                            ><span
                                class="material-symbols-rounded text-[14px] opacity-0 -ml-4 group-hover:opacity-100 group-hover:ml-0 transition-all text-brand-secondary"
                                >chevron_right</span
                            > Contáctanos</a>
                    </li>
                </ul>
            </div>

            <!-- Columna 3: Contacto Directo -->
            <div>
                <h3
                    class="text-brand-primary font-bold text-lg mb-6 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 bg-brand-secondary rounded-full"
                    ></span> Ubicación y Contacto
                </h3>
                <div class="space-y-5">
                    <div class="flex items-start gap-4 group">
                        <div
                            class="w-9 h-9 rounded-xl bg-white shadow-sm border border-gray-100 flex items-center justify-center group-hover:bg-brand-secondary transition-colors duration-300 shrink-0"
                        >
                            <span
                                class="material-symbols-rounded text-brand-secondary group-hover:text-white text-[20px]"
                                >location_on</span
                            >
                        </div>
                        <p class="text-gray-600 text-xs leading-relaxed mt-1">
                            Av. Despensa N° 1550<br />J.L. Ortiz, Lambayeque –
                            Perú
                        </p>
                    </div>
                    <div class="flex items-center gap-4 group">
                        <div
                            class="w-9 h-9 rounded-xl bg-white shadow-sm border border-gray-100 flex items-center justify-center group-hover:bg-brand-secondary transition-colors duration-300 shrink-0"
                        >
                            <span
                                class="material-symbols-rounded text-brand-secondary group-hover:text-white text-[20px]"
                                >call</span
                            >
                        </div>
                        <div class="text-gray-600 text-xs flex flex-col gap-1">
                            <p>+51 922 398 538</p>
                            <p>+51 973 845 374</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 group">
                        <div
                            class="w-9 h-9 rounded-xl bg-white shadow-sm border border-gray-100 flex items-center justify-center group-hover:bg-brand-secondary transition-colors duration-300 shrink-0"
                        >
                            <span
                                class="material-symbols-rounded text-brand-secondary group-hover:text-white text-[20px]"
                                >mail</span
                            >
                        </div>
                        <div
                            class="text-gray-600 text-[11px] sm:text-xs break-all mt-1 flex flex-col gap-1"
                        >
                            <a
                                href="mailto:exportadoranorandino@gmail.com"
                                class="hover:text-brand-secondary transition-colors"
                                >exportadoranorandino@gmail.com</a
                            >
                            <a
                                href="mailto:info@exportadoranorandino.com"
                                class="hover:text-brand-secondary transition-colors"
                                >info@exportadoranorandino.com</a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Copyright -->
        <div
            class="mt-8 pt-8 border-t border-gray-200 text-center flex flex-col md:flex-row justify-between items-center gap-4"
        >
            <p
                class="text-gray-500 text-[11px] uppercase tracking-widest font-medium"
            >
                &copy; 2026 Exportadora Norandino S.A.C.
            </p>
            <p class="text-gray-400 text-[10px] uppercase tracking-widest">
                Todos los derechos reservados.
            </p>
        </div>
    </div>
</footer>

<style>
    h3 {
        letter-spacing: 0.025em;
    }
</style>
