---
// src/components/ExportMap.astro
---

<section
  id="exportaciones"
  class="pt-8 md:pt-10 pb-12 md:pb-16 bg-white relative overflow-visible"
>
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span
        class="text-brand-secondary font-semibold text-sm tracking-widest uppercase"
        >Alcance Global</span
      >
      <h2
        class="font-heading text-3xl md:text-5xl font-bold text-brand-primary mt-2 mb-4"
      >
        Exportamos al Mundo
      </h2>
      <div class="section-divider mx-auto mb-6"></div>
      <p
        class="text-gray-600 max-w-2xl mx-auto text-sm md:text-lg leading-relaxed"
      >
        Llevamos la calidad de la agricultura peruana a mercados
        internacionales, garantizando frescura e inocuidad en cada destino.
      </p>
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <!-- LEFT: Country cards + Map -->
      <div
        class="bg-gray-50/50 rounded-[2rem] shadow-xl border border-gray-100 p-4 md:p-6 relative flex flex-col gap-4"
      >
        <!-- Country cards ABOVE the map -->
        <div class="grid grid-cols-3 gap-3">
          <!-- Colombia -->
          <div
            class="flex flex-col items-center bg-white rounded-2xl p-3 border border-gray-100 shadow-sm hover:shadow-md transition-shadow"
          >
            <img
              src="https://flagcdn.com/w40/co.png"
              srcset="https://flagcdn.com/w80/co.png 2x"
              alt="Colombia"
              class="w-8 h-auto rounded mb-1 shadow-sm"
            />
            <p
              class="font-bold text-gray-800 text-xs text-center leading-tight"
            >
              Colombia
            </p>
          </div>
          <!-- República Dominicana -->
          <div
            class="flex flex-col items-center bg-white rounded-2xl p-3 border border-gray-100 shadow-sm hover:shadow-md transition-shadow"
          >
            <img
              src="https://flagcdn.com/w40/do.png"
              srcset="https://flagcdn.com/w80/do.png 2x"
              alt="República Dominicana"
              class="w-8 h-auto rounded mb-1 shadow-sm"
            />
            <p
              class="font-bold text-gray-800 text-xs text-center leading-tight"
            >
              Rep. Dominicana
            </p>
          </div>
          <!-- Costa Rica -->
          <div
            class="flex flex-col items-center bg-white rounded-2xl p-3 border border-gray-100 shadow-sm hover:shadow-md transition-shadow"
          >
            <img
              src="https://flagcdn.com/w40/cr.png"
              srcset="https://flagcdn.com/w80/cr.png 2x"
              alt="Costa Rica"
              class="w-8 h-auto rounded mb-1 shadow-sm"
            />
            <p
              class="font-bold text-gray-800 text-xs text-center leading-tight"
            >
              Costa Rica
            </p>
          </div>
        </div>

        <!-- Map -->
        <div id="vmap" class="w-full z-10 relative" style="height: 400px;">
        </div>

        <!-- Legend -->
        <div
          class="bg-white px-4 py-3 rounded-xl shadow-md border border-gray-100 flex flex-wrap items-center gap-4 text-xs font-medium w-fit mx-auto"
        >
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-brand-primary inline-block"
            ></span>
            <span class="text-gray-700">Origen (Perú)</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded bg-brand-secondary inline-block"
            ></span>
            <span class="text-gray-700">Destinos</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Respaldo y Certificaciones -->
      <div class="flex flex-col justify-center overflow-hidden">
        <!-- Franja de color superior -->

        <div class="flex flex-col py-10 px-8">
          <!-- Encabezado -->
          <div class="text-center mb-8">
            <span
              class="text-brand-secondary font-semibold text-md tracking-widest uppercase block"
            >
              Respaldo y Certificaciones
            </span>
            <div class="w-12 h-1 bg-brand-secondary mx-auto mt-2 rounded-full">
            </div>
          </div>

          <!-- Bloque 1: Certificado en cada envío -->
          <div class="flex flex-col items-center text-center pb-8">
            <p
              class="text-brand-primary text-xs font-semibold uppercase tracking-widest mb-4"
            >
              Contamos con certificado en cada envío de:
            </p>
            <img
              src="senasa2.png"
              alt="Institución Certificadora"
              class="max-h-28 w-auto object-contain"
            />
          </div>

          <!-- Separador -->
          <div
            class="w-2/3 mx-auto h-px mb-8"
            style="background: linear-gradient(90deg, #0071bc55, #39b54a55);"
          >
          </div>

          <!-- Bloque 2: Pertenecemos a -->
          <div class="flex flex-col items-center text-center">
            <p
              class="text-brand-primary text-xs font-semibold uppercase tracking-widest mb-4"
            >
              Pertenecemos a:
            </p>
            <img
              src="prom.png"
              alt="Asociación o Membresía"
              class="max-h-28 w-auto object-contain"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- jsVectorMap CSS and JS -->
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/jsvectormap/dist/css/jsvectormap.min.css"
/>
<script is:inline src="https://cdn.jsdelivr.net/npm/jsvectormap"></script>
<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/jsvectormap/dist/maps/world.js"></script>

<script is:inline>
  document.addEventListener("astro:page-load", initMap);
  document.addEventListener("DOMContentLoaded", initMap);

  function initMap() {
    var mapContainer = document.getElementById("vmap");
    if (!mapContainer || mapContainer.children.length > 0) return;

    // Only the 3 export destinations
    var exportDestinations = ["CO", "DO", "CR"];

    var isMobile = window.innerWidth < 1024;
    var map = new jsVectorMap({
      selector: "#vmap",
      map: "world",
      zoomOnScroll: false,
      zoomButtons: false,
      backgroundColor: "transparent",
      focusOn: isMobile
        ? { coords: [6, -68], scale: 5 }
        : { coords: [5, -78], scale: 4.5 },
      selectedRegions: exportDestinations,
      regionStyle: {
        initial: {
          fill: "#e2e8f0",
          stroke: "#ffffff",
          strokeWidth: 0.5,
          fillOpacity: 1,
        },
        hover: {
          fillOpacity: 0.8,
          cursor: "pointer",
        },
        selected: {
          fill: "#39b54a",
        },
        selectedHover: {
          fill: "#2eaa40",
        },
      },
      markers: [{ name: "Perú (Sede Principal)", coords: [-9.19, -75.01] }],
      markerStyle: {
        initial: { fill: "#0071bc", r: 7, stroke: "#ffffff", strokeWidth: 3 },
        hover: { r: 9 },
      },
      onRegionTooltipShow(event, tooltip, code) {
        var names = {
          CO: "Colombia",
          DO: "República Dominicana",
          CR: "Costa Rica",
          PE: "Perú",
        };
        if (code === "PE") {
          tooltip.text("Perú — Centro de Producción y Exportación");
        } else if (exportDestinations.includes(code)) {
          tooltip.text(
            (names[code] || tooltip.text()) + " — Destino de Exportación",
          );
        }
      },
    });

    // Force re-render at the correct container size
    setTimeout(function () {
      if (map && typeof map.updateSize === "function") {
        map.updateSize();
      }
    }, 100);
  }
</script>
