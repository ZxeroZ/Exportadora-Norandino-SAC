---
// src/pages/contacto.astro
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
---

<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" href="/logo.png" />
        <title>Contacto | Exportadora Norandino S.A.C.</title>
        <meta
            name="description"
            content="Comunícate con Exportadora Norandino S.A.C. para obtener información sobre nuestros productos agrícolas de exportación."
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0"
            rel="stylesheet"
        />
    </head>
    <body
        class="bg-white text-gray-800 font-body antialiased flex flex-col min-h-screen"
    >
        <Navbar />

        <!-- Padding restored for standard flow -->
        <main class="flex-grow pt-4 pb-16 px-6">
            <div class="max-w-6xl mx-auto">
                <!-- HEADER -->
                <div class="text-center mb-8 mt-2">
                    <span
                        class="text-brand-secondary font-semibold text-xs tracking-widest uppercase"
                        >Comunícate</span
                    >
                    <h1
                        class="font-heading text-3xl md:text-5xl font-bold text-brand-primary mt-2 mb-3"
                    >
                        Contacto
                    </h1>
                    <div class="section-divider mx-auto mb-4"></div>
                    <p class="text-gray-600 text-sm md:text-lg">
                        ¿Interesado en nuestros productos? Contáctanos hoy mismo
                    </p>
                </div>

                <!-- CONTENT GRID -->
                <div
                    class="grid lg:grid-cols-2 gap-6 md:gap-12 items-start mb-10 md:mb-16"
                >
                    <!-- LEFT SIDE: Contact Info -->
                    <div class="space-y-6 md:space-y-10">
                        <!-- Dirección -->
                        <div class="flex gap-4">
                            <div
                                class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center shrink-0"
                            >
                                <span
                                    class="material-symbols-rounded text-brand-primary"
                                    >location_on</span
                                >
                            </div>
                            <div>
                                <h3
                                    class="font-heading font-bold text-gray-900 text-lg mb-1"
                                >
                                    Dirección
                                </h3>
                                <p
                                    class="text-gray-600 leading-relaxed text-sm"
                                >
                                    Av. Despensa N° 1550<br />
                                    José Leonardo Ortiz<br />
                                    Lambayeque, Perú
                                </p>
                            </div>
                        </div>

                        <!-- Teléfono -->
                        <div class="flex gap-4">
                            <div
                                class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center shrink-0"
                            >
                                <span
                                    class="material-symbols-rounded text-brand-primary"
                                    >call</span
                                >
                            </div>
                            <div>
                                <h3
                                    class="font-heading font-bold text-gray-900 text-lg mb-1"
                                >
                                    Teléfono
                                </h3>
                                <div
                                    class="text-gray-600 leading-relaxed text-sm flex flex-col gap-1"
                                >
                                    <a
                                        href="tel:+51921113910"
                                        class="hover:text-brand-secondary transition-colors"
                                        >+51 921 113 910</a
                                    >
                                    <a
                                        href="tel:+51922398538"
                                        class="hover:text-brand-secondary transition-colors"
                                        >+51 922 398 538</a
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="flex gap-4">
                            <div
                                class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center shrink-0"
                            >
                                <span
                                    class="material-symbols-rounded text-brand-primary"
                                    >mail</span
                                >
                            </div>
                            <div>
                                <h3
                                    class="font-heading font-bold text-gray-900 text-lg mb-1"
                                >
                                    Email
                                </h3>
                                <p
                                    class="text-gray-600 leading-relaxed text-sm"
                                >
                                    exportadoranorandino@gmail.com<br />
                                    info.exponorandino@gmail.com
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT SIDE: Contact Form -->
                    <div
                        class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 md:p-8"
                    >
                        <h2
                            class="font-heading text-xl md:text-2xl font-bold text-gray-900 mb-4 md:mb-6"
                        >
                            Envíanos un Mensaje
                        </h2>
                        <form
                            class="space-y-4"
                            action="#"
                            method="POST"
                            id="contact-form"
                        >
                            <div>
                                <label
                                    for="nombre"
                                    class="block text-sm font-medium text-gray-700 mb-1"
                                    >Nombre</label
                                >
                                <input
                                    type="text"
                                    id="nombre"
                                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-primary focus:border-brand-primary outline-none transition-all"
                                    placeholder="Tu nombre"
                                    required
                                />
                            </div>
                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-medium text-gray-700 mb-1"
                                    >Email</label
                                >
                                <input
                                    type="email"
                                    id="email"
                                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-primary focus:border-brand-primary outline-none transition-all"
                                    placeholder="tu@email.com"
                                    required
                                />
                            </div>

                            <div>
                                <label
                                    for="mensaje"
                                    class="block text-sm font-medium text-gray-700 mb-1"
                                    >Mensaje</label
                                >
                                <textarea
                                    id="mensaje"
                                    rows="4"
                                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-primary focus:border-brand-primary outline-none transition-all resize-none"
                                    placeholder="¿En qué podemos ayudarte?"
                                    required></textarea>
                            </div>
                            <button
                                type="submit"
                                class="w-full bg-brand-primary hover:bg-[#005a96] text-white font-bold py-3 px-6 rounded-lg transition-colors mt-4"
                            >
                                Enviar Mensaje
                            </button>
                        </form>
                        <script is:inline>
                            (function () {
                                var f = document.getElementById("contact-form");
                                if (!f) return;
                                f.addEventListener("submit", function (e) {
                                    e.preventDefault();
                                    var n =
                                        document.getElementById("nombre")
                                            .value || "";
                                    var em =
                                        document.getElementById("email")
                                            .value || "";
                                    var msg =
                                        document.getElementById("mensaje")
                                            .value || "";
                                    var txt = encodeURIComponent(
                                        "Hola, soy " +
                                            n +
                                            ", el correo de contacto es: " +
                                            em +
                                            " y mi consulta es: " +
                                            msg,
                                    );

                                    window.open(
                                        "https://wa.me/51921113910?text=" + txt,
                                        "_blank",
                                    );
                                    f.reset();
                                });
                            })();
                        </script>
                    </div>
                </div>

                <!-- BOTTOM: Map Section -->
                <div
                    class="w-full h-96 bg-gray-200 rounded-2xl overflow-hidden shadow-inner relative"
                >
                    <iframe
                        title="Ubicación de Exportadora Norandino S.A.C."
                        width="100%"
                        height="100%"
                        frameborder="0"
                        src="https://maps.google.com/maps?q=Centro+Campestre+La+Despensa,+José+Leonardo+Ortiz,+Lambayeque,+Perú&t=&z=17&ie=UTF8&iwloc=&output=embed"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </main>

        <Footer />
        <WhatsAppButton />
    </body>
</html>
