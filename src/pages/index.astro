---
// src/pages/index.astro
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ProductCarousel from "../components/ProductCarousel.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import ExportMap from "../components/ExportMap.astro";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>Exportadora Norandino S.A.C.</title>
    <meta
      name="description"
      content="Empresa peruana dedicada a la exportación de cebolla, ajo y jengibre fresco con los más altos estándares de calidad e inocuidad."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-gray-800 font-body antialiased">
    <!-- Popups -->

    <!-- ==================== NAVBAR ==================== -->
    <Navbar />

    <section class="pb-8 md:px-6 px-4 bg-white overflow-hidden">
      <div
        class="max-w-7xl mx-auto relative rounded-2xl md:rounded-[2.5rem] overflow-hidden h-[65vmax] md:h-[calc(100vh-140px)] min-h-[400px] md:min-h-[550px] flex items-center"
      >
        <!-- Background Image -->
        <div class="absolute inset-0 bg-[#06140b]">
          <img
            src="/img1.jpg"
            alt="Campo de cebollas"
            class="w-full h-full object-cover opacity-100"
          />
          <!-- Degradado de negro/verde oscuro a transparente -->
          <div
            class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-transparent"
          >
          </div>
        </div>
        <!-- Content -->
        <div class="relative z-10 p-6 md:p-12 lg:p-16 w-full mt-24 md:mt-0">
          <div class="max-w-xl">
            <div class="animate-fade-up">
              <span
                class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-[10px] md:text-xs font-semibold px-3 py-1.5 rounded-full mb-3 md:mb-4 border border-white/20 w-fit"
              >
                <span
                  class="material-symbols-rounded text-sm md:text-base leading-none"
                  >eco</span
                >
                <span class="leading-none pt-[1px]"
                  >Productos Agrícolas Peruanos</span
                >
              </span>
            </div>
            <h1
              class="animate-fade-up delay-100 font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4"
            >
              Calidad Agrícola Para El Mundo
            </h1>
            <p
              class="animate-fade-up delay-200 text-base md:text-md text-white/90 font-light mb-6 max-w-lg"
            >
              Nos enfocamos en ofrecer productos agrícolas de calidad con
              procesos confiables y eficientes.
            </p>
            <div class="animate-fade-up delay-300 flex flex-wrap gap-3">
              <a
                href="https://wa.me/51921113910"
                target="_blank"
                rel="noopener"
                class="bg-brand-primary hover:bg-brand-primary/90 text-white font-bold py-2.5 px-6 rounded-full transition-all duration-300 hover:shadow-xl hover:shadow-brand-primary/30 hover:-translate-y-1 flex items-center gap-2 text-sm"
              >
                Más información <span class="material-symbols-rounded text-base"
                  >arrow_outward</span
                >
              </a>
            </div>

            <!-- Floating Cards (only visible on desktop) -->
            <div
              class="animate-fade-up delay-400 hidden md:flex flex-wrap items-center gap-3 mt-16"
            >
              <!-- Dark Card -->
              <div
                class="bg-[#2D333F]/90 backdrop-blur-md rounded-2xl p-3 md:p-4 flex items-center gap-3 border border-white/10 shadow-2xl w-[220px]"
              >
                <div
                  class="w-10 h-10 rounded-full bg-brand-secondary/20 flex flex-shrink-0 items-center justify-center"
                >
                  <div
                    class="w-4 h-4 rounded-full bg-brand-secondary blur-[2px]"
                  >
                  </div>
                </div>
                <div>
                  <div
                    class="flex items-center gap-1 text-white font-bold text-base mb-0.5"
                  >
                    <span class="material-symbols-rounded text-xs text-gray-400"
                      >verified</span
                    > SENASA
                  </div>
                  <p class="text-[10px] text-gray-300 leading-tight">
                    Certificación y Empaque
                  </p>
                </div>
              </div>

              <!-- Light Card -->
              <div
                class="bg-white/95 backdrop-blur-md rounded-2xl p-3 md:p-4 flex items-center gap-3 shadow-2xl w-[220px]"
              >
                <div
                  class="w-10 h-10 rounded-full bg-brand-tertiary flex flex-shrink-0 items-center justify-center text-white shadow-inner"
                >
                  <span class="material-symbols-rounded text-[20px]">star</span>
                </div>
                <div>
                  <div
                    class="font-bold text-gray-800 text-[12px] leading-tight mb-0.5"
                  >
                    Control de Calidad
                  </div>
                  <p class="text-[9px] text-gray-500 leading-tight">
                    Procesos de selección y verificación
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mobile-only: Cards below the hero, stacked vertically -->
    <div class="flex md:hidden flex-row gap-3 px-4 pb-6 bg-white">
      <!-- Dark Card -->
      <div
        class="bg-[#2D333F] rounded-2xl p-4 flex items-center gap-3 border border-brand-secondary/50 shadow-md w-full"
      >
        <div
          class="w-10 h-10 rounded-full bg-brand-secondary/20 flex flex-shrink-0 items-center justify-center"
        >
          <div class="w-4 h-4 rounded-full bg-brand-secondary blur-[2px]"></div>
        </div>
        <div>
          <div
            class="flex items-center gap-1 text-white font-bold text-sm mb-0"
          >
            <span class="material-symbols-rounded text-xs text-gray-400"
              >verified</span
            >
            SENASA
          </div>
          <p class="text-[10px] text-gray-300 leading-tight">
            Certificación y Empaque
          </p>
        </div>
      </div>

      <!-- Light Card -->
      <div
        class="bg-white rounded-2xl p-4 flex items-center gap-3 shadow-md border border-brand-primary/30 w-full"
      >
        <div
          class="w-10 h-10 rounded-full bg-brand-tertiary flex flex-shrink-0 items-center justify-center text-white shadow-inner"
        >
          <span class="material-symbols-rounded text-[20px]">star</span>
        </div>
        <div>
          <div class="font-bold text-gray-800 text-[13px] leading-tight">
            Control de Calidad
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== QUIÉNES SOMOS ==================== -->
    <section
      id="nosotros"
      class="pt-12 md:pt-16 pb-8 md:pb-12 px-6 relative overflow-hidden bg-gray-50/50"
    >
      <div
        class="max-w-7xl mx-auto reveal-on-scroll opacity-0 translate-y-8 transition-all duration-1000 ease-out"
      >
        <!-- Section Header -->
        <div class="text-center mb-16">
          <span
            class="text-brand-secondary font-semibold text-sm tracking-widest uppercase"
            >Conócenos</span
          >
          <h2
            class="font-heading text-4xl md:text-5xl font-bold text-brand-primary mt-2 mb-4"
          >
            ¿Quiénes Somos?
          </h2>
          <div class="section-divider mx-auto"></div>
        </div>
        <!-- Grid -->
        <div class="grid lg:grid-cols-3 gap-8">
          <!-- About Card -->
          <div
            class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 card-lift"
          >
            <div
              class="w-14 h-14 rounded-xl bg-gray-50 flex items-center justify-center mb-6"
            >
              <span
                class="material-symbols-rounded text-3xl text-brand-secondary"
                >apartment</span
              >
            </div>
            <h3 class="font-heading text-2xl font-bold text-brand-primary mb-4">
              Nuestra Empresa
            </h3>
            <p class="text-gray-600 leading-relaxed text-justify">
              Exportadora Norandino S.A.C. es una empresa peruana dedicada al
              procesamiento, selección, empaque y exportación de productos
              agrícolas como <strong class="font-bold"
                >cebolla (roja y amarilla), ajo y jengibre fresco</strong
              >. Trabajamos bajo estrictos estándares de calidad e inocuidad
              para ofrecer productos confiables en mercados internacionales.
            </p>
            <div class="section-divider mt-6"></div>
          </div>
          <!-- Misión -->
          <div
            class="bg-brand-secondary/15 rounded-2xl shadow-lg border border-brand-secondary/30 card-lift relative flex flex-col overflow-hidden group"
          >
            <div class="h-48 overflow-hidden">
              <img
                src="img2.jpg"
                alt="Cebollas en cajas"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
            </div>
            <div class="p-8">
              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-lg bg-brand-secondary/10 flex items-center justify-center shrink-0"
                >
                  <span class="material-symbols-rounded text-brand-secondary"
                    >track_changes</span
                  >
                </div>
                <h3 class="font-heading text-2xl font-bold text-brand-primary">
                  Misión
                </h3>
              </div>
              <p class="text-gray-600 leading-relaxed text-sm">
                Garantizar a nuestros clientes productos frescos de cebolla, ajo
                y jengibre que cumplen estándares internacionales de calidad e
                inocuidad, mediante procesos eficientes y un compromiso
                constante con la mejora continua.
              </p>
            </div>
          </div>
          <!-- Visión -->
          <div
            class="bg-brand-primary/15 rounded-2xl shadow-lg border border-brand-primary/30 card-lift relative flex flex-col overflow-hidden group"
          >
            <div class="h-48 overflow-hidden">
              <img
                src="img3.jpg"
                alt="Exportación agrícola"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
            </div>
            <div class="p-8">
              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-lg bg-brand-primary/10 flex items-center justify-center shrink-0"
                >
                  <span class="material-symbols-rounded text-brand-primary"
                    >visibility</span
                  >
                </div>
                <h3 class="font-heading text-2xl font-bold text-brand-primary">
                  Visión
                </h3>
              </div>
              <p class="text-gray-600 leading-relaxed text-sm">
                Ser una empresa exportadora líder y confiable en el mercado
                internacional, reconocida por la excelencia de nuestros
                productos y por relaciones comerciales sostenibles.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== PRODUCTOS ==================== -->
    <section
      id="productos"
      class="pt-8 md:pt-12 pb-12 md:pb-16 px-6 bg-gradient-to-b from-gray-50/50 to-white relative overflow-hidden"
    >
      <div
        class="max-w-7xl mx-auto reveal-on-scroll opacity-0 translate-y-8 transition-all duration-1000 ease-out"
      >
        <div class="text-center mb-10">
          <span
            class="text-brand-secondary font-semibold text-sm tracking-widest uppercase"
            >Catálogo</span
          >
          <h2
            class="font-heading text-4xl md:text-5xl font-bold text-brand-primary mt-2 mb-4"
          >
            Nuestros Productos
          </h2>
          <div class="section-divider mx-auto"></div>
        </div>

        <div
          class="grid grid-cols-2 md:grid-cols-4 md:grid-rows-3 gap-3 md:gap-4 md:h-[700px] max-w-6xl mx-auto mb-16"
        >
          <!-- Fila 1: Col 1 — mobile: full width hero -->
          <div
            class="col-span-2 md:col-span-1 h-[200px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img11.jpeg"
              alt="Galería 1"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Fila 1+2: Col 2 (Unida hacia abajo) — mobile: normal 1 col -->
          <div
            class="col-span-1 md:col-span-1 md:row-span-2 h-[180px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img9.jpeg"
              alt="Galería 2"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Col 3+4 — mobile: 1 col -->
          <div
            class="col-span-1 md:col-span-2 h-[180px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img8.jpeg"
              alt="Galería 3"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Fila 2: Col 1 — mobile: 1 col -->
          <div
            class="col-span-1 md:col-span-1 h-[180px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img4.jpeg"
              alt="Galería 4"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Fila 2: Col 3 — mobile: 1 col -->
          <div
            class="col-span-1 md:col-span-1 h-[180px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img10.jpeg"
              alt="Galería 5"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Fila 2+3: Col 4 (Unida hacia abajo) — mobile: normal 1 col -->
          <div
            class="col-span-1 md:col-span-1 md:row-span-2 h-[180px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img5.jpeg"
              alt="Galería 6"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Fila 3: Col 3 — mobile: 1 col (sube aquí para llenar el espacio) -->
          <div
            class="col-span-1 md:col-span-1 h-[180px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img6.jpg"
              alt="Galería 8"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Fila 3: Col 1+2 unidas — mobile: full width final -->
          <div
            class="col-span-2 md:col-span-2 h-[160px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img7.jpg"
              alt="Galería 7"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
        </div>
        <!-- PRODUCT CAROUSEL -->
        <ProductCarousel />
      </div>
    </section>
  </body>

  <!-- ==================== CALIDAD ==================== -->
  <section
    id="calidad"
    class="pt-8 md:pt-12 pb-12 md:pb-16 px-6 relative overflow-hidden"
  >
    <div
      class="max-w-7xl mx-auto reveal-on-scroll opacity-0 translate-y-8 transition-all duration-1000 ease-out"
    >
      <div class="text-center mb-6">
        <span
          class="text-brand-secondary font-semibold text-sm tracking-widest uppercase"
          >Excelencia</span
        >
        <h2
          class="font-heading text-4xl md:text-5xl font-bold text-brand-primary mt-2 mb-4"
        >
          Proceso y Control de Calidad
        </h2>
        <div class="section-divider mx-auto"></div>
      </div>

      <div class="text-center max-w-sm mx-auto mb-10">
        <p class="text-gray-600 text-sm">
          Nuestro proceso integral garantiza la calidad desde la recepción hasta
          la exportación respaldado por la certificación SENASA.
        </p>
      </div>

      <!-- Timeline Alternada (Izquierda/Derecha) -->
      <div class="relative w-full max-w-4xl mx-auto px-4 mt-4">
        <!-- Línea Vertical Central (Desktop) / Izquierda (Mobile) con Degradado Vertical -->
        <div
          class="absolute left-10 md:left-1/2 top-4 bottom-4 w-1 bg-gradient-to-b from-brand-secondary via-brand-tertiary to-brand-primary md:-translate-x-1/2 z-0"
        >
        </div>

        <div class="space-y-10 md:space-y-16 relative z-10 w-full py-4">
          <!-- Paso 1: Recepción -->
          <div
            class="flex flex-row md:flex-row items-center w-full group relative reveal-timeline opacity-0 translate-y-8 transition-all duration-700 ease-out"
          >
            <!-- Izquierda Desktop -->
            <div class="hidden md:flex md:w-1/2 justify-end pr-10">
              <div
                class="bg-white border-2 border-brand-secondary/30 rounded-xl p-6 shadow-sm w-full max-w-sm text-right relative hover:shadow-md transition-all"
              >
                <div
                  class="absolute top-1/2 -right-2.5 w-5 h-5 bg-white border-t-2 border-r-2 border-brand-secondary/30 transform rotate-45 -translate-y-1/2"
                >
                </div>
                <div
                  class="text-xs font-bold text-brand-secondary uppercase tracking-widest mb-1"
                >
                  Paso 01
                </div>
                <h4 class="font-bold text-gray-800 text-lg mb-2">Recepción</h4>
                <p class="text-sm text-gray-600">
                  Ingreso y clasificación inicial del producto directo desde el
                  campo hacia nuestras instalaciones.
                </p>
              </div>
            </div>

            <!-- Círculo -->
            <div
              class="w-12 h-12 md:w-16 md:h-16 shrink-0 md:mx-auto rounded-full border-[4px] border-white bg-brand-secondary flex items-center justify-center shadow-md z-10 ml-4 md:ml-0 relative group-hover:scale-110 transition-transform"
            >
              <span
                class="material-symbols-rounded text-lg md:text-2xl text-white"
                >agriculture</span
              >
            </div>

            <!-- Derecha Mobile -->
            <div class="md:hidden ml-6 w-full pr-4">
              <div
                class="bg-white border-2 border-brand-secondary/30 rounded-xl p-5 shadow-sm relative w-full"
              >
                <div
                  class="absolute top-6 -left-2.5 w-5 h-5 bg-white border-b-2 border-l-2 border-brand-secondary/30 transform rotate-45"
                >
                </div>
                <div
                  class="text-[10px] font-bold text-brand-secondary uppercase tracking-widest mb-1"
                >
                  Paso 01
                </div>
                <h4 class="font-bold text-gray-800 text-base mb-1">
                  Recepción
                </h4>
                <p class="text-sm text-gray-600">
                  Ingreso y clasificación inicial del producto directo desde el
                  campo.
                </p>
              </div>
            </div>

            <!-- Derecha Vacío Desktop -->
            <div class="hidden md:block w-1/2 pl-10"></div>
          </div>

          <!-- Paso 2: Selección Manual -->
          <div
            class="flex flex-row md:flex-row items-center w-full group relative reveal-timeline opacity-0 translate-y-8 transition-all duration-700 ease-out delay-100"
          >
            <!-- Izquierda Vacío Desktop -->
            <div class="hidden md:block w-1/2 pr-10"></div>

            <!-- Círculo -->
            <div
              class="w-12 h-12 md:w-16 md:h-16 shrink-0 md:mx-auto rounded-full border-[4px] border-white bg-brand-tertiary flex items-center justify-center shadow-md z-10 ml-4 md:ml-0 relative group-hover:scale-110 transition-transform"
            >
              <span
                class="material-symbols-rounded text-lg md:text-2xl text-white"
                >pan_tool</span
              >
            </div>

            <!-- Derecha -->
            <div class="ml-6 md:ml-0 md:w-1/2 md:pl-10 w-full pr-4 md:pr-0">
              <div
                class="bg-white border-2 border-brand-tertiary/30 rounded-xl p-5 md:p-6 shadow-sm relative w-full max-w-sm hover:shadow-md transition-all"
              >
                <div
                  class="absolute top-6 md:top-1/2 -left-2.5 w-5 h-5 bg-white border-b-2 border-l-2 border-brand-tertiary/30 transform rotate-45 md:-translate-y-1/2"
                >
                </div>
                <div
                  class="text-[10px] md:text-xs font-bold text-brand-tertiary uppercase tracking-widest mb-1"
                >
                  Paso 02
                </div>
                <h4
                  class="font-bold text-gray-800 text-base md:text-lg mb-1 md:mb-2"
                >
                  Selección Manual
                </h4>
                <p class="text-sm text-gray-600">
                  Revisión exhaustiva y descarte de unidades dañadas o fuera de
                  norma.
                </p>
              </div>
            </div>
          </div>

          <!-- Paso 3: Clasificación -->
          <div
            class="flex flex-row md:flex-row items-center w-full group relative reveal-timeline opacity-0 translate-y-8 transition-all duration-700 ease-out delay-200"
          >
            <!-- Izquierda Desktop -->
            <div class="hidden md:flex md:w-1/2 justify-end pr-10">
              <div
                class="bg-white border-2 border-[#2e9e7b]/30 rounded-xl p-6 shadow-sm w-full max-w-sm text-right relative hover:shadow-md transition-all"
              >
                <div
                  class="absolute top-1/2 -right-2.5 w-5 h-5 bg-white border-t-2 border-r-2 border-[#2e9e7b]/30 transform rotate-45 -translate-y-1/2"
                >
                </div>
                <div
                  class="text-xs font-bold text-[#2e9e7b] uppercase tracking-widest mb-1"
                >
                  Paso 03
                </div>
                <h4 class="font-bold text-gray-800 text-lg mb-2">
                  Clasificación
                </h4>
                <p class="text-sm text-gray-600">
                  Agrupación cuidadosa por calibres y tamaños según los
                  requerimientos.
                </p>
              </div>
            </div>

            <!-- Círculo -->
            <div
              class="w-12 h-12 md:w-16 md:h-16 shrink-0 md:mx-auto rounded-full border-[4px] border-white bg-[#2e9e7b] flex items-center justify-center shadow-md z-10 ml-4 md:ml-0 relative group-hover:scale-110 transition-transform"
            >
              <span
                class="material-symbols-rounded text-lg md:text-2xl text-white"
                >straighten</span
              >
            </div>

            <!-- Derecha Mobile -->
            <div class="md:hidden ml-6 w-full pr-4">
              <div
                class="bg-white border-2 border-[#2e9e7b]/30 rounded-xl p-5 shadow-sm relative w-full"
              >
                <div
                  class="absolute top-6 -left-2.5 w-5 h-5 bg-white border-b-2 border-l-2 border-[#2e9e7b]/30 transform rotate-45"
                >
                </div>
                <div
                  class="text-[10px] font-bold text-[#2e9e7b] uppercase tracking-widest mb-1"
                >
                  Paso 03
                </div>
                <h4 class="font-bold text-gray-800 text-base mb-1">
                  Clasificación
                </h4>
                <p class="text-sm text-gray-600">
                  Agrupación cuidadosa por calibres y tamaños según los
                  requerimientos.
                </p>
              </div>
            </div>

            <!-- Derecha Vacío Desktop -->
            <div class="hidden md:block w-1/2 pl-10"></div>
          </div>

          <!-- Paso 4: Empaque -->
          <div
