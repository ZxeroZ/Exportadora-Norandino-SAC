---
// src/pages/index.astro
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ProductCarousel from "../components/ProductCarousel.astro";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>Exportadora Norandino S.A.C.</title>
    <meta
      name="description"
      content="Empresa peruana dedicada a la exportación de cebolla, ajo y jengibre fresco con los más altos estándares de calidad e inocuidad."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-gray-800 font-body antialiased">
    <!-- ==================== NAVBAR ==================== -->
    <Navbar />

    <section class="pb-8 px-6 bg-white overflow-hidden">
      <div
        class="max-w-7xl mx-auto relative rounded-[2.5rem] overflow-hidden h-[calc(100vh-140px)] min-h-[500px] flex items-center"
      >
        <!-- Background Image -->
        <div class="absolute inset-0 bg-[#06140b]">
          <img
            src="/img1.jpg"
            alt="Campo de cebollas"
            class="w-full h-full object-cover opacity-100"
          />
          <!-- Degradado de negro/verde oscuro a transparente -->
          <div
            class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-transparent"
          >
          </div>
        </div>
        <!-- Content -->
        <div class="relative z-10 p-8 md:p-12 lg:p-16 w-full">
          <div class="max-w-xl">
            <div class="animate-fade-up">
              <span
                class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-[10px] md:text-xs font-semibold px-3 py-1.5 rounded-full mb-3 md:mb-4 border border-white/20 w-fit"
              >
                <span
                  class="material-symbols-rounded text-sm md:text-base leading-none"
                  >eco</span
                >
                <span class="leading-none pt-[1px]"
                  >Productos Agrícolas Peruanos</span
                >
              </span>
            </div>
            <h1
              class="animate-fade-up delay-100 font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4"
            >
              Calidad Agrícola Para El Mundo
            </h1>
            <p
              class="animate-fade-up delay-200 text-base md:text-md text-white/90 font-light mb-6 max-w-lg"
            >
              Nos enfocamos en ofrecer productos agrícolas de calidad con
              procesos confiables y eficientes.
            </p>
            <div class="animate-fade-up delay-300 flex flex-wrap gap-3">
              <a
                href="https://wa.me/51999999999"
                target="_blank"
                rel="noopener"
                class="bg-brand-primary hover:bg-brand-primary/90 text-white font-bold py-2.5 px-6 rounded-full transition-all duration-300 hover:shadow-xl hover:shadow-brand-primary/30 hover:-translate-y-1 flex items-center gap-2 text-sm"
              >
                Más información <span class="material-symbols-rounded text-base"
                  >arrow_outward</span
                >
              </a>
            </div>

            <!-- Floating Cards -->
            <div
              class="animate-fade-up delay-400 flex flex-wrap items-center gap-3 mt-8 md:mt-16"
            >
              <!-- Dark Card -->
              <div
                class="bg-[#2D333F]/90 backdrop-blur-md rounded-2xl p-3 md:p-4 flex items-center gap-3 border border-white/10 shadow-2xl w-[220px]"
              >
                <div
                  class="w-10 h-10 rounded-full bg-brand-secondary/20 flex flex-shrink-0 items-center justify-center"
                >
                  <div
                    class="w-4 h-4 rounded-full bg-brand-secondary blur-[2px]"
                  >
                  </div>
                </div>
                <div>
                  <div
                    class="flex items-center gap-1 text-white font-bold text-base mb-0.5"
                  >
                    <span class="material-symbols-rounded text-xs text-gray-400"
                      >verified</span
                    > SENASA
                  </div>
                  <p class="text-[10px] text-gray-300 leading-tight">
                    Certificación y Empaque
                  </p>
                </div>
              </div>

              <!-- Light Card -->
              <div
                class="bg-white/95 backdrop-blur-md rounded-2xl p-3 md:p-4 flex items-center gap-3 shadow-2xl w-[220px]"
              >
                <div
                  class="w-10 h-10 rounded-full bg-brand-tertiary flex flex-shrink-0 items-center justify-center text-white shadow-inner"
                >
                  <span class="material-symbols-rounded text-[20px]">star</span>
                </div>
                <div>
                  <div
                    class="font-bold text-gray-800 text-[12px] leading-tight mb-0.5"
                  >
                    Control de Calidad
                  </div>
                  <p class="text-[9px] text-gray-500 leading-tight">
                    Procesos de selección y verificación
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== QUIÉNES SOMOS ==================== -->
    <section
      id="nosotros"
      class="pt-12 md:pt-16 pb-4 md:pb-8 px-6 relative overflow-hidden"
    >
      <div class="max-w-7xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <span
            class="text-brand-secondary font-semibold text-sm tracking-widest uppercase"
            >Conócenos</span
          >
          <h2
            class="font-heading text-4xl md:text-5xl font-bold text-brand-primary mt-2 mb-4"
          >
            ¿Quiénes Somos?
          </h2>
          <div class="section-divider mx-auto"></div>
        </div>
        <!-- Grid -->
        <div class="grid lg:grid-cols-3 gap-8">
          <!-- About Card -->
          <div
            class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 card-lift"
          >
            <div
              class="w-14 h-14 rounded-xl bg-gray-50 flex items-center justify-center mb-6"
            >
              <span
                class="material-symbols-rounded text-3xl text-brand-secondary"
                >apartment</span
              >
            </div>
            <h3 class="font-heading text-2xl font-bold text-brand-primary mb-4">
              Nuestra Empresa
            </h3>
            <p class="text-gray-600 leading-relaxed">
              Exportadora Norandino S.A.C. es una empresa peruana dedicada al
              procesamiento, selección, empaque y exportación de productos
              agrícolas como <strong
                >cebolla (roja y amarilla), ajo y jengibre fresco</strong
              >. Trabajamos bajo estrictos estándares de calidad e inocuidad
              para ofrecer productos confiables en mercados internacionales.
            </p>
            <div class="section-divider mt-6"></div>
          </div>
          <!-- Misión -->
          <div class="green-card card-lift relative overflow-hidden">
            <div
              class="absolute top-0 right-0 w-32 h-32 rounded-full bg-white/5 -mr-10 -mt-10"
            >
            </div>
            <img
              src="img2.jpg"
              alt="Cebollas en cajas"
              class="w-full h-48 object-cover rounded-xl mb-6"
            />
            <h3 class="font-heading text-2xl font-bold mb-4">MISIÓN</h3>
            <p class="text-white/90 leading-relaxed text-sm">
              Garantizar a nuestros clientes productos frescos de cebolla, ajo y
              jengibre que cumplen estándares internacionales de calidad e
              inocuidad, mediante procesos eficientes y un compromiso constante
              con la mejora continua.
            </p>
          </div>
          <!-- Visión -->
          <div class="blue-card card-lift relative overflow-hidden">
            <div
              class="absolute top-0 right-0 w-32 h-32 rounded-full bg-white/5 -mr-10 -mt-10"
            >
            </div>
            <img
              src="img3.jpg"
              alt="Exportación agrícola"
              class="w-full h-48 object-cover rounded-xl mb-6"
            />
            <h3 class="font-heading text-2xl font-bold mb-4">VISIÓN</h3>
            <p class="text-white/90 leading-relaxed text-sm">
              Ser una empresa exportadora líder y confiable en el mercado
              internacional, reconocida por la excelencia de nuestros productos
              y por relaciones comerciales sostenibles.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== PRODUCTOS ==================== -->
    <section
      id="productos"
      class="pt-8 md:pt-12 pb-12 md:pb-16 px-6 bg-gradient-to-b from-gray-50/50 to-white relative overflow-hidden"
    >
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <span
            class="text-brand-secondary font-semibold text-sm tracking-widest uppercase"
            >Catálogo</span
          >
          <h2
            class="font-heading text-4xl md:text-5xl font-bold text-brand-primary mt-2 mb-4"
          >
            Nuestros Productos
          </h2>
          <div class="section-divider mx-auto"></div>
        </div>

        <div
          class="grid grid-cols-2 md:grid-cols-4 md:grid-rows-2 gap-4 md:h-[400px] max-w-6xl mx-auto mb-16"
        >
          <div
            class="col-span-2 md:col-span-1 md:col-start-1 md:col-end-2 md:row-start-1 md:row-end-3 h-[200px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img5.jpg"
              alt="Instalaciones 1"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          <div
            class="col-span-1 md:col-start-2 md:col-end-4 md:row-start-1 md:row-end-2 h-[160px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img4.jpg"
              alt="Instalaciones 2"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          <div
            class="col-span-1 md:col-start-2 md:col-end-4 md:row-start-2 md:row-end-3 h-[160px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img7.jpg"
              alt="Instalaciones 3"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          <div
            class="col-span-2 md:col-span-1 md:col-start-4 md:col-end-5 md:row-start-1 md:row-end-3 h-[200px] md:h-auto rounded-2xl overflow-hidden group shadow-md"
          >
            <img
              src="img6.jpg"
              alt="Instalaciones 4"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
        </div>
        <!-- PRODUCT CAROUSEL -->
        <ProductCarousel />
      </div>
    </section>
  </body>

  <!-- ==================== CALIDAD ==================== -->
  <section
    id="calidad"
    class="pt-8 md:pt-12 pb-12 md:pb-16 px-6 relative overflow-hidden"
  >
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span
          class="text-brand-secondary font-semibold text-sm tracking-widest uppercase"
          >Excelencia</span
        >
        <h2
          class="font-heading text-4xl md:text-5xl font-bold text-brand-primary mt-2 mb-4"
        >
          Proceso y Control de Calidad
        </h2>
        <div class="section-divider mx-auto"></div>
      </div>

      <!-- Quality Process Description -->
      <div
        class="bg-gradient-to-br from-brand-primary to-brand-primary rounded-3xl p-10 mb-12 text-white relative overflow-hidden"
      >
        <div class="flex items-start gap-6 flex-col md:flex-row">
          <div class="icon-circle bg-white/20 flex-shrink-0">
            <span class="material-symbols-rounded text-3xl"
              >workspace_premium</span
            >
          </div>
          <div>
            <h3 class="font-heading text-2xl font-bold mb-4">
              Nuestro Proceso
            </h3>
            <p class="text-white/85 leading-relaxed text-lg">
              Nuestro proceso integra selección manual, clasificación por
              calibres, limpieza, empaque y verificación final en planta. Todos
              los envíos cuentan con trazabilidad, inspección previa y
              certificación fitosanitaria emitida por el <strong
                >Servicio Nacional de Sanidad Agraria – SENASA</strong
              >.
            </p>
          </div>
        </div>
        <!-- Process Steps -->
        <div
          class="grid grid-cols-2 md:grid-cols-5 gap-4 mt-10 pt-8 border-t border-white/10"
        >
          <div class="text-center">
            <div
              class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3"
            >
              <span class="material-symbols-rounded">agriculture</span>
            </div>
            <p class="text-sm text-white/80 font-medium">Recepción</p>
          </div>
          <div class="text-center">
            <div
              class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3"
            >
              <span class="material-symbols-rounded">pan_tool</span>
            </div>
            <p class="text-sm text-white/80 font-medium">Selección Manual</p>
          </div>
          <div class="text-center">
            <div
              class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3"
            >
              <span class="material-symbols-rounded">straighten</span>
            </div>
            <p class="text-sm text-white/80 font-medium">Clasificación</p>
          </div>
          <div class="text-center">
            <div
              class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3"
            >
              <span class="material-symbols-rounded">inventory_2</span>
            </div>
            <p class="text-sm text-white/80 font-medium">Empaque</p>
          </div>
          <div class="text-center">
            <div
              class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center mx-auto mb-3"
            >
              <span class="material-symbols-rounded">local_shipping</span>
            </div>
            <p class="text-sm text-white/80 font-medium">Exportación</p>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Ventajas Competitivas -->
        <div
          class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 card-lift"
        >
          <div class="flex items-center gap-4 mb-6">
            <div class="icon-circle">
              <span class="material-symbols-rounded">trending_up</span>
            </div>
            <h3 class="font-heading text-xl font-bold text-brand-primary">
              Ventajas Competitivas
            </h3>
          </div>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-2 h-2 rounded-full bg-brand-secondary mt-2 flex-shrink-0"
              ></span>
              Producto uniforme y selección manual
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-2 h-2 rounded-full bg-brand-secondary mt-2 flex-shrink-0"
              ></span>
              Experiencia exportando a Colombia y República Dominicana
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-2 h-2 rounded-full bg-brand-secondary mt-2 flex-shrink-0"
              ></span>
              Flexibilidad para adaptarnos a los requisitos del cliente
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-2 h-2 rounded-full bg-brand-secondary mt-2 flex-shrink-0"
              ></span>
              Precios competitivos y abastecimiento continuo
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-2 h-2 rounded-full bg-brand-secondary mt-2 flex-shrink-0"
              ></span>
              Planta propia ubicada en Chiclayo, zona agrícola estratégica
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-2 h-2 rounded-full bg-brand-secondary mt-2 flex-shrink-0"
              ></span>
              Comunicación directa y eficiente durante todo el proceso
            </li>
          </ul>
        </div>

        <!-- Certificaciones -->
        <div
          class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 card-lift"
        >
          <div class="flex items-center gap-4 mb-6">
            <div class="icon-circle">
              <span class="material-symbols-rounded">verified_user</span>
            </div>
            <h3 class="font-heading text-xl font-bold text-brand-primary">
              Certificaciones
            </h3>
          </div>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-brand-primary flex-shrink-0"
                ><span class="material-symbols-rounded text-sm">check</span
                ></span
              >
              Certificado fitosanitario SENASA N° 000170-MINAGRI-SENASA-LAMBAYEQUE
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-brand-primary flex-shrink-0"
                ><span class="material-symbols-rounded text-sm">check</span
                ></span
              >
              Código SENASA planta empacadora: N° 004-00058PE
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-brand-primary text-xs flex-shrink-0"
                >✓</span
              >
              Certificado de origen (cámara de comercio)
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-brand-primary text-xs flex-shrink-0"
                >✓</span
              >
              Trazabilidad garantizada
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-brand-primary text-xs flex-shrink-0"
                >✓</span
              >
              Buenas prácticas de manipulación
            </li>
            <li class="flex items-start gap-3 text-gray-600">
              <span
                class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-brand-primary text-xs flex-shrink-0"
                >✓</span
              >
              Cumplimiento de requisitos sanitarios y legales del país de origen
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FOOTER / CONTACTO ==================== -->
  <Footer />

  <!-- ==================== SCRIPTS ==================== -->
  <script>
    // Intersection Observer for scroll animations
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("animate-fade-up");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    document.querySelectorAll("section > div").forEach((el) => {
      observer.observe(el);
    });
  </script>
</html>
